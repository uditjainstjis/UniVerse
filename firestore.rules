rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, universitySuffix, createdAt
    //
    // Collection: queries
    // Fields: id, authorUid, authorName, authorPhoto, content, imageUrl, upvotes, downvotes, status, createdAt
    //
    // Collection: blinkit_requests
    // Fields: id, authorUid, authorName, authorPhoto, itemDescription, windowMinutes, expiresAt, joinedUids, status, createdAt
    //
    // Collection: buddy_posts
    // Fields: id, authorUid, authorName, authorPhoto, category, title, description, createdAt
    //
    // Collection: notifications
    // Fields: id, recipientUid, title, message, type, read, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "18january2007@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function isRecipient() {
      return isAuthenticated() && request.auth.uid == resource.data.recipientUid;
    }

    function isSender() {
      return isAuthenticated() && request.auth.uid == resource.data.senderUid;
    }

    function isParticipant() {
      return isAuthenticated() && 
             resource != null && 
             'participants' in resource.data && 
             request.auth.uid in resource.data.participants;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() < 100 &&
             data.universitySuffix is string &&
             data.createdAt is number;
    }

    function isValidQuery(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string &&
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 2000 &&
             data.upvotes is list &&
             data.downvotes is list &&
             data.status in ['pending', 'resolved', 'archived'] &&
             data.createdAt is number;
    }

    function isValidBlinkit(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string &&
             data.itemDescription is string &&
             data.itemDescription.size() > 0 &&
             data.itemDescription.size() < 500 &&
             data.windowMinutes is number &&
             data.expiresAt is number &&
             data.joinedUids is list &&
             data.status in ['active', 'expired', 'completed'] &&
             data.createdAt is number;
    }

    function isValidBuddy(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string &&
             data.category in ['gym', 'swimming', 'coffee', 'cab', 'vacation', 'other'] &&
             data.title is string &&
             data.title.size() > 0 &&
             data.title.size() < 200 &&
             data.description is string &&
             data.description.size() > 0 &&
             data.description.size() < 1000 &&
             data.createdAt is number;
    }

    function isValidMessage(data) {
      return data.senderUid == request.auth.uid &&
             data.recipientUid is string &&
             data.participants is list &&
             data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 5000 &&
             data.createdAt is number &&
             data.read is bool;
    }

    function isValidChatSession(data) {
      return data.participants is list &&
             data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /queries/{queryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQuery(request.resource.data);
      allow update: if isAuthenticated() && (
        (isDocOwner() && isValidQuery(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes']))
      );
      allow delete: if isDocOwner() || isAdmin();
    }

    match /blinkit_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBlinkit(request.resource.data);
      allow update: if isAuthenticated() && (
        (isDocOwner() && isValidBlinkit(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedUids']))
      );
    }

    match /buddy_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBuddy(request.resource.data);
      allow update: if isDocOwner() && isValidBuddy(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isRecipient();
      allow update: if isRecipient() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isRecipient();
    }

    match /messages/{messageId} {
      allow read: if isParticipant();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if isRecipient() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /chat_sessions/{sessionId} {
      allow read: if isParticipant();
      allow create: if isAuthenticated() && isValidChatSession(request.resource.data);
      allow update: if isParticipant() && isValidChatSession(request.resource.data);
    }
  }
}
